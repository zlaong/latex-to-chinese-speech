{
  "name": "latex-to-chinese-speech",
  "version": "0.1.0",
  "description": "Convert LaTeX math formulas to Chinese speech text, powered by temml + speech-rule-engine (clearspeak). Suitable for feeding into any TTS engine (Volcano seed-tts, Alibaba, Azure, etc.).",
  "keywords": [
    "latex",
    "mathml",
    "tts",
    "speech",
    "chinese",
    "math",
    "accessibility",
    "clearspeak",
    "mathspeak",
    "speech-rule-engine"
  ],
  "license": "MIT",
  "author": "zlaong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zlaong/latex-to-chinese-speech.git"
  },
  "homepage": "https://github.com/zlaong/latex-to-chinese-speech#readme",
  "bugs": {
    "url": "https://github.com/zlaong/latex-to-chinese-speech/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "speech-rule-engine": "^4.1.4",
    "temml": "^0.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "~5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
